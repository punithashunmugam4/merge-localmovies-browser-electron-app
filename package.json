  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "28.0.0",
    "electron-builder": "24.9.1",
    "electron-rebuild": "3.2.9"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "axios": "^1.16.1",
